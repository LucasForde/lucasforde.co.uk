---
const title = "Lucas Forde";
const strapline = "Web Design and Development";
---

<section class="fixed-scene" data-fixed-scene aria-hidden="true">
  <h1 class="site-title site-title--ghost" data-ghost-title>
    {title}
    <span>{strapline}</span>
  </h1>
  <div class="image-layer image-layer--dash" data-image-layer="dash"></div>
  <div class="image-layer image-layer--code" data-image-layer="code"></div>
</section>
