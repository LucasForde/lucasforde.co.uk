---
import "../styles/global.css";
import Loader from "../components/Loader.astro";
import Hero from "../components/Hero.astro";
import FixedScene from "../components/FixedScene.astro";
import Intro from "../components/Intro.astro";
import ContactHeading from "../components/ContactHeading.astro";
import Contact from "../components/Contact.astro";
import { STATIC_LAYOUT_MEDIA_QUERY, STATIC_LAYOUT_USER_AGENT_TOKENS } from "../scripts/static-layout";

const title = "Lucas Forde | Web Design and Development | Tunbridge Wells";
const description = "Frontend web developer focused on thoughtful design, clean code, and responsive user interfaces.";
const staticLayoutUserAgentTokens = STATIC_LAYOUT_USER_AGENT_TOKENS;
const staticLayoutMediaQuery = STATIC_LAYOUT_MEDIA_QUERY;
---

<!doctype html>
<html lang="en" class="is-loading">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script define:vars={{ staticLayoutMediaQuery, staticLayoutUserAgentTokens }}>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      scrollTo(0, 0);

      const userAgent = navigator.userAgent.toLowerCase();
      const matchesStaticLayoutUserAgent = staticLayoutUserAgentTokens.some((token) => userAgent.includes(token));
      const staticLayoutQuery = matchMedia(staticLayoutMediaQuery);

      if (matchesStaticLayoutUserAgent || staticLayoutQuery.matches) {
        document.documentElement.classList.add("is-static-layout");
        document.documentElement.classList.remove("is-loading");
      }
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="is-loading">
    <Loader />

    <main class="site" data-site>
      <Hero />
      <FixedScene />
      <Intro />
      <ContactHeading />
      <Contact />
    </main>

    <script>
      import "../scripts/loader.ts";
      import "../scripts/scroll.ts";
    </script>
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "827c404ff7704328a9a52b24be5c8b24"}'
    ></script>
    <!-- End Cloudflare Web Analytics -->
  </body>
</html>
