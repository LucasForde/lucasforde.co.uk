---
import "../styles/global.css";
import Loader from "../components/Loader.astro";
import Hero from "../components/Hero.astro";
import FixedScene from "../components/FixedScene.astro";
import Intro from "../components/Intro.astro";
import ContactHeading from "../components/ContactHeading.astro";
import Contact from "../components/Contact.astro";

const title = "Lucas Forde - Web Design and Development - Tunbridge Wells";
const description = "Frontend web developer focused on thoughtful design, clean code, and responsive user interfaces.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020c2c" />
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      scrollTo(0, 0);
    </script>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="is-loading">
    <Loader />

    <main class="site" data-site>
      <Hero />
      <FixedScene />
      <Intro />
      <ContactHeading />
      <Contact />
    </main>

    <script>
      import "../scripts/loader.ts";
      import "../scripts/scroll.ts";
    </script>
  </body>
</html>
